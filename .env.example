APP_NAME="SecureShare"
APP_ENV=production
APP_URL=https://YOUR-SUBDOMAIN.epizy.com

DB_CONNECTION=sqlite
DB_DATABASE=storage/database.sqlite

# Generate keys by running: php -r "echo base64_encode(random_bytes(32));"
APP_KEY=base64:GENERATE_A_KEY_HERE
ENCRYPTION_KEY=GENERATE_ANOTHER_KEY_HERE

# AI Integration (Get your key from https://aistudio.google.com/)
AI_API_KEY=YOUR_AI_API_KEY

# Google OAuth (Get credentials from https://console.cloud.google.com/apis/credentials)
# IMPORTANT: Add your deployed URL as authorized redirect URI in Google Console
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Groq API for AI Chatbot (Get key from https://console.groq.com)
GROQ_API_KEY=YOUR_GROQ_API_KEY

# Server Admin Authentication
SERVER_ADMIN_SECRET=CHANGE_THIS_TO_A_STRONG_SECRET
SERVER_ADMIN_EMAIL=your-email@gmail.com

# Gmail SMTP Configuration (Required for OTP emails)
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Generate an App Password for "Mail"
# 3. Put your Gmail and App Password below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=YOUR_APP_PASSWORD
SMTP_FROM_NAME=SecureShare
